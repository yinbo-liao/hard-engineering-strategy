# Application
APP_NAME=Hardness Control Plane
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://hardness:hardness@localhost:5432/hardness
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# Claude Code / MCP
CLAUDE_API_KEY=xxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
MCP_SERVER_URL=http://localhost:3001

# Hardness
MAX_ITERATIONS=5
MAX_COST_PER_TASK=5.0
TASK_TIMEOUT_SECONDS=300
RETRY_COUNT=3

# Security
SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Sandbox
SANDBOX_NETWORK_MODE=none
SANDBOX_CPU_LIMIT=1
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_TIMEOUT_SECONDS=300

# Evaluation
TEST_COVERAGE_THRESHOLD=80
SECURITY_SCAN_ENABLED=true
LINT_CHECK_ENABLED=true

# Notifications (optional)
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
