{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && harness check --files \"$CLAUDE_TOOL_INPUT_FILE_PATH\" --json 2>&1 || true",
            "timeout": 15000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash\\(git push.*\\)",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && harness check --path . --scope security --json 2>&1 || true",
            "timeout": 30000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd \"$CLAUDE_PROJECT_DIR\" && harness init --path . --if-missing 2>&1 || true",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(harness:*)",
      "Bash(harness check:*)",
      "Bash(harness init:*)",
      "Bash(harness evaluate:*)",
      "Bash(harness plan:*)",
      "Bash(harness bench:*)",
      "Bash(harness metrics:*)"
    ]
  }
}
